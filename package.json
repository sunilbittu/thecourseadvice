{
  "name": "thecourseadvice",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "nx dev web",
    "dev:admin": "nx dev admin",
    "build": "nx build web",
    "build:admin": "nx build admin",
    "build:all": "nx run-many --target=build",
    "lint": "nx run-many --target=lint",
    "db:push": "set -a && . ./.env.local && set +a && drizzle-kit push",
    "db:seed": "set -a && . ./.env.local && set +a && npx tsx packages/db/src/seed.ts",
    "db:generate": "set -a && . ./.env.local && set +a && drizzle-kit generate",
    "db:studio": "set -a && . ./.env.local && set +a && drizzle-kit studio"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "bcryptjs": "^2.4.3",
    "@gsap/react": "^2.1.2",
    "@neondatabase/serverless": "^1.0.2",
    "@stripe/stripe-js": "^9.1.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "gsap": "^3.14.2",
    "lucide-react": "^1.8.0",
    "next": "16.2.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.2.0",
    "stripe": "^22.0.1",
    "jose": "^6.0.11",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "tailwindcss": "^4",
    "typescript": "^5",
    "nx": "22.6.5",
    "@nx/next": "22.6.5"
  }
}
